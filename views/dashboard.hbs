<section class="page-head">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-sub">All of your fuel records at a glance.</p>
  </div>
  <a href="/records/new" class="btn btn-primary">Add Record</a>
</section>

<section class="stat-grid">
  <article class="stat-card">
    <span class="stat-label">Records</span>
    <span class="stat-value">{{stats.totals.recordCount}}</span>
  </article>
  <article class="stat-card">
    <span class="stat-label">Total Spent</span>
    <span class="stat-value">${{stats.totals.totalCost}}</span>
  </article>
  <article class="stat-card">
    <span class="stat-label">Liters</span>
    <span class="stat-value">{{stats.totals.totalLiters}} L</span>
  </article>
  <article class="stat-card">
    <span class="stat-label">Distance</span>
    <span class="stat-value">{{stats.totals.totalDistance}} km</span>
  </article>
  <article class="stat-card">
    <span class="stat-label">Avg km/L</span>
    <span class="stat-value">{{stats.totals.avgKmPerLiter}}</span>
  </article>
</section>

<section class="card">
  <header class="card-head">
    <h2 class="card-title">Fuel Records</h2>
    <a href="/summary" class="btn btn-ghost">View Summary</a>
  </header>

  {{#if records.length}}
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Vehicle</th>
          <th class="num">Liters</th>
          <th class="num">Distance (km)</th>
          <th class="num">Total Cost</th>
          <th class="num">km/L</th>
          <th class="num">Cost/km</th>
          <th class="actions">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each records}}
          <tr>
            <td>{{this.date}}</td>
            <td><span class="pill pill-{{toLower this.vehicleType}}">{{this.vehicleType}}</span></td>
            <td class="num">{{this.liters}}</td>
            <td class="num">{{this.distance}}</td>
            <td class="num">${{this.totalCost}}</td>
            <td class="num">{{this.kmPerLiter}}</td>
            <td class="num">${{this.costPerKm}}</td>
            <td class="actions">
              <a class="btn btn-sm btn-ghost" href="/records/{{this.id}}/edit">Edit</a>
              <form action="/records/{{this.id}}/delete" method="POST" class="inline-form" onsubmit="return confirm('Delete this record?');">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}" />
                <button class="btn btn-sm btn-danger" type="submit">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
    <div class="empty-state">
      <p>No records yet. Add your first fuel entry to start tracking.</p>
      <a href="/records/new" class="btn btn-primary">Add Record</a>
    </div>
  {{/if}}
</section>
