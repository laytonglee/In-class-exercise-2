<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} | Fuel Manager</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <span class="brand-mark"></span>
        <span class="brand-name">Fuel Manager</span>
      </a>
      <nav class="primary-nav">
        {{#if currentUser}}
          <a href="/dashboard" class="nav-link">Dashboard</a>
          <a href="/summary" class="nav-link">Summary</a>
          <a href="/records/new" class="nav-link">Add Record</a>
          <span class="nav-user">{{currentUser.username}}</span>
          <form action="/logout" method="POST" class="inline-form">
            <input type="hidden" name="_csrf" value="{{csrfToken}}" />
            <button type="submit" class="btn btn-ghost">Sign out</button>
          </form>
        {{else}}
          <a href="/login" class="nav-link">Sign In</a>
          <a href="/register" class="nav-link nav-cta">Create Account</a>
        {{/if}}
      </nav>
    </div>
  </header>

  <main class="container page">
    {{#if flash}}
      <div class="flash flash-{{flash.type}}">{{flash.message}}</div>
    {{/if}}
    {{{body}}}
  </main>

  <footer class="site-footer">
    <div class="container">
      <small>INF 653 &middot; Fuel Consumption Manager &middot; Express + Handlebars + JWT + CSRF</small>
    </div>
  </footer>
</body>
</html>
